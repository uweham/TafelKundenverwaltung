<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="579.0" prefWidth="430.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="kundenverwaltung.controller.ShowDeletedPersonsController">
    <children>
        <BorderPane maxHeight="600.0" maxWidth="430.0" prefHeight="576.0" prefWidth="430.0">
            <bottom>
                <HBox alignment="CENTER" prefHeight="45.0" prefWidth="430.0" BorderPane.alignment="CENTER_RIGHT">
               <children>
                  <VBox alignment="CENTER_RIGHT" prefHeight="21.0" prefWidth="408.0">
                     <children>
                        <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#btnCancelDeletePerson" text="Abbrechen">
                           <opaqueInsets>
                              <Insets />
                           </opaqueInsets>
                        </Button>
                     </children>
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                  </VBox>
               </children>
                </HBox>
            </bottom>
            <top>
                <HBox alignment="CENTER" prefHeight="54.0" prefWidth="430.0" style="-fx-background-color: white;" BorderPane.alignment="CENTER">
                    <children>
                        <Label fx:id="labelHeading" text="Gelöschte Personen" textFill="#ee6f00" wrapText="true">
                            <HBox.margin>
                                <Insets left="15.0" />
                            </HBox.margin>
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                    </children>
                    <BorderPane.margin>
                        <Insets />
                    </BorderPane.margin>
                </HBox>
            </top>
            <center>
                <VBox prefHeight="477.0" prefWidth="430.0" BorderPane.alignment="CENTER">
                    <children>
                  <HBox alignment="BOTTOM_LEFT" prefHeight="34.0" prefWidth="384.0">
                     <children>
                        <VBox prefHeight="34.0" prefWidth="14.0" />
                        <Label fx:id="labelListDeletedPersons" prefHeight="17.0" prefWidth="236.0" text="Liste gelöschter Familienmitglieder">
                           <opaqueInsets>
                              <Insets />
                           </opaqueInsets>
                        </Label>
                     </children>
                     <opaqueInsets>
                        <Insets left="10.0" />
                     </opaqueInsets>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="250.0" prefWidth="430.0">
                     <children>
                        <TableView fx:id="tableViewDeletedPersons">
                          <columns>
                              <TableColumn fx:id="columnId" prefWidth="30.0" text="ID" />
                            <TableColumn fx:id="columnName" prefWidth="182.0" text="Name" />
                            <TableColumn fx:id="columnBirthday" prefWidth="98.0" text="Geburtsdatum" />
                              <TableColumn fx:id="columnDeletedOn" prefWidth="92.0" text="Gelöscht am" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </HBox>
                        <HBox alignment="BOTTOM_LEFT" prefHeight="28.0" prefWidth="430.0">
                            <children>
                                <VBox prefHeight="41.0" prefWidth="15.0" />
                                <Label fx:id="labelReasonDelete" text="Grund der Löschung:" />
                            </children>
                        </HBox>
                        <HBox alignment="TOP_CENTER" prefHeight="158.0" prefWidth="430.0">
                            <children>
                                <TextArea fx:id="textAreaReasonDeletePerson" editable="false" prefHeight="156.0" prefWidth="407.0" />
                            </children>
                        </HBox>
                  <HBox alignment="CENTER" prefHeight="18.0" prefWidth="430.0" />
                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</AnchorPane>
