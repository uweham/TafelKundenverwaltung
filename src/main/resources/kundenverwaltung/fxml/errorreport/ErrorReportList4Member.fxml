<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0" prefWidth="1040.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="kundenverwaltung.controller.errorreport.ErrorReportList4MemberController">
    <top>
        <VBox prefHeight="92.0" prefWidth="831.0" spacing="10.0">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>
            <children>
                <Label text="Übersicht Ihrer gemeldeten Fehlerberichte">
                    <font>
                        <Font name="System Bold" size="18" />
                    </font>
                </Label>
                <TextField fx:id="searchTextField" promptText="Fehlerberichte durchsuchen..." />
            </children>
        </VBox>
    </top>

    <center>
        <TableView fx:id="errorReportTable" prefHeight="673.0" prefWidth="1010.0" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="titleColumn" prefWidth="200.0" text="Titel" />
                <TableColumn fx:id="descriptionColumn" prefWidth="450.0" text="Beschreibung" />
                <TableColumn fx:id="statusColumn" prefWidth="100.0" text="Status" />
                <TableColumn fx:id="createdAtColumn" prefWidth="80.0" text="Abgeschickt am" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <BorderPane.margin>
                <Insets bottom="15.0" left="15.0" right="15.0" />
            </BorderPane.margin>
        </TableView>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" prefHeight="0.0" prefWidth="1040.0" spacing="10.0">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <children>
                <Button fx:id="newButton" onAction="#onBtnClickNewErrorReport" text="Neuen Fehler melden" />
                <Button fx:id="deleteButton" onAction="#onBtnClickDeleteErrorReport" text="Eintrag löschen" />
                <HBox HBox.hgrow="ALWAYS" />
                <Button fx:id="refreshButton" onAction="#onBtnClickRefreshList" text="Aktualisieren" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
