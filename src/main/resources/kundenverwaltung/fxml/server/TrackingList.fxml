<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0" prefWidth="1040.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="kundenverwaltung.controller.server.TrackingListController">
    <top>
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>
            <children>
                <Label text="Client Tracking Übersicht">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <TextField fx:id="suchFeld" promptText="Nach UUID oder Programmversion suchen..." />
            </children>
        </VBox>
    </top>

    <center>
        <TableView fx:id="trackingTabelle" prefHeight="674.0" prefWidth="1010.0" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="uuidSpalte" prefWidth="300.0" text="Client Hash" />
                <TableColumn fx:id="versionSpalte" prefWidth="150.0" text="Programmversion" />
                <TableColumn fx:id="letzteAktivitaetSpalte" prefWidth="200.0" text="Zuletzt gesehen" />
                <TableColumn fx:id="erstelltAmSpalte" prefWidth="200.0" text="Erstmals gesehen" />
                <TableColumn fx:id="tafelLocationSpalte" prefWidth="200.0" text="Verteilstelle" />
                <TableColumn fx:id="tafelNameSpalte" text="Tafelname" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <BorderPane.margin>
                <Insets bottom="15.0" left="15.0" right="15.0" />
            </BorderPane.margin>
        </TableView>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <padding>
                <Insets bottom="15" left="15" right="15" top="10" />
            </padding>
            <children>
                <Button fx:id="aktualisierenButton" onAction="#handleAktualisieren" text="Aktualisieren" />
                <HBox HBox.hgrow="ALWAYS" />
                <Button fx:id="schliessenButton" onAction="#handleSchliessen" text="Schließen" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
