<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="kundenverwaltung.controller.KontaktdatenBearbeitenController">
   <children>
      <BorderPane prefHeight="258.0" prefWidth="395.0">
         <bottom>
            <HBox prefHeight="40.0" prefWidth="395.0" BorderPane.alignment="CENTER">
               <children>
                  <Button fx:id="btnKontaktdatenOK" mnemonicParsing="false" onAction="#btnKontaktdatenOK" prefWidth="105.0" text="OK">
                     <HBox.margin>
                        <Insets right="165.0" />
                     </HBox.margin>
                  </Button>
                  <Button fx:id="btnKontaktdatenAbbrechen" mnemonicParsing="false" onAction="#btnKontaktdatenAbbrechen" prefWidth="105.0" text="Abbrechen" />
               </children>
               <BorderPane.margin>
                  <Insets left="10.0" right="10.0" />
               </BorderPane.margin>
            </HBox>
         </bottom>
         <center>
            <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
               <children>
                  <VBox prefHeight="180.0" prefWidth="201.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label fx:id="labelStreet" text="Straße">
                           <VBox.margin>
                              <Insets left="10.0" top="10.0" />
                           </VBox.margin>
                        </Label>
                        <TextField fx:id="txtKDStrasse" >
                           <VBox.margin>
                              <Insets left="10.0" right="10.0" />
                           </VBox.margin>
                        </TextField>
                        <Label fx:id="labelPostcode" text="PLZ">
                           <VBox.margin>
                              <Insets left="10.0" top="10.0" />
                           </VBox.margin>
                        </Label>
                        <TextField fx:id="txtKDPostleitzahl" layoutX="10.0" layoutY="30.0">
                           <VBox.margin>
                              <Insets left="10.0" right="10.0" />
                           </VBox.margin>
                        </TextField>
                        <Label fx:id="labelPhoneNumber" text="Telefonnummer">
                           <VBox.margin>
                              <Insets left="10.0" top="10.0" />
                           </VBox.margin>
                        </Label>
                        <TextField fx:id="txtKDTelefonnummer" layoutX="10.0" layoutY="82.0">
                           <VBox.margin>
                              <Insets left="10.0" right="10.0" />
                           </VBox.margin>
                        </TextField>
                     </children>
                  </VBox>
                  <VBox layoutX="10.0" layoutY="10.0" prefHeight="180.0" prefWidth="201.0">
                     <children>
                        <Label fx:id="labelHouseNumber" text="Hausnummer">
                           <VBox.margin>
                              <Insets left="10.0" top="10.0" />
                           </VBox.margin>
                        </Label>
                        <TextField fx:id="txtKDHausnummer">
                           <VBox.margin>
                              <Insets left="10.0" right="10.0" />
                           </VBox.margin>
                        </TextField>
                        <Label fx:id="labelLocation" text="Wohnort">
                           <VBox.margin>
                              <Insets left="10.0" top="10.0" />
                           </VBox.margin>
                        </Label>
                        <TextField fx:id="txtKDWohnort" layoutX="10.0" layoutY="30.0">
                           <VBox.margin>
                              <Insets left="10.0" right="10.0" />
                           </VBox.margin>
                        </TextField>
                        <Label fx:id="labelMobilNumber" text="Mobiltelefon-Nr.">
                           <VBox.margin>
                              <Insets left="10.0" top="10.0" />
                           </VBox.margin>
                        </Label>
                        <TextField fx:id="txtKDMobiltelefon" layoutX="10.0" layoutY="82.0">
                           <VBox.margin>
                              <Insets left="10.0" right="10.0" />
                           </VBox.margin>
                        </TextField>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </center>
         <top>
            <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: white;" BorderPane.alignment="CENTER">
               <children>
                  <Label fx:id="labelHeading" text="Geben Sie hier die Kontaktdaten des Kunden ein." textFill="#ee6f00">
                     <HBox.margin>
                        <Insets left="10.0" />
                     </HBox.margin>
                  </Label>
               </children>
            </HBox>
         </top>
      </BorderPane>
   </children>
</AnchorPane>
