<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="1040.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="kundenverwaltung.controller.errorreport.ErrorReportSubmitController">

    <VBox spacing="25" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">

        <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-alignment: CENTER;" text="Fehlerbericht" />

        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #fff8e1; -fx-padding: 10; -fx-border-color: #ffd54f; -fx-border-width: 1;">

            <ImageView fitHeight="50" fitWidth="50">
                <image>
                    <Image preserveRatio="true" url="@Error.png" />
                </image>
            </ImageView>

            <VBox spacing="2">
                <Label fx:id="hintTitle" prefHeight="29.0" prefWidth="100.0" style="-fx-text-fill: #e65100; -fx-font-weight: bold;" text="Achtung!" />
                <Label fx:id="hintText" prefHeight="34.0" prefWidth="519.0" style="-fx-text-fill: #e65100;" text="Ein Fehler ist aufgetreten. Sie können einen Bericht an die Hochschule Osnabrück senden." wrapText="true" />
            </VBox>
        </HBox>

        <VBox spacing="2" AnchorPane.topAnchor="10">
            <Label text="Bitte beschreiben Sie, wie der Fehler aufgetreten ist:" />
            <TextArea fx:id="userDescriptionTextArea" prefRowCount="4" wrapText="true" />
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Screenshot hochladen:" />
            <Button fx:id="screenshotButton" text="Datei auswählen" />
            <Label fx:id="selectedFileLabel" text="Keine Datei ausgewählt" />
        </HBox>

        <VBox spacing="5">
            <Label text="Letzte Logs:" />

            <TableView fx:id="tableViewLogs" prefHeight="400" prefWidth="680">
                <columns>
                    <TableColumn fx:id="colTimestamp" prefWidth="80" text="Zeitstempel" />
                    <TableColumn fx:id="colLevel" prefWidth="60" text="Level" />
                    <TableColumn fx:id="colSource" prefWidth="140" text="Quelle" />
                    <TableColumn fx:id="colMessage" prefWidth="400" text="Nachricht" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>

        <Label style="-fx-text-fill: red; -fx-font-size: 11px;" text="Dieser Fehlerbericht wird anonym an die Hochschule Osnabrück übermittelt. Bitte keine persönlichen Daten eintragen." wrapText="true" />

        <HBox alignment="CENTER_RIGHT" spacing="20">
            <Button fx:id="sendReportToServerButton" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120;" text="Absenden" />
            <Button fx:id="screenshotCaptureButton" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120;" text="Screenshot" />
            <Button fx:id="cancelButton" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120;" text="Abbrechen" />
        </HBox>

    </VBox>
</AnchorPane>
