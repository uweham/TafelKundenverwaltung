<configuration debug="true">
    <property name="LOG_PATH" value="${log.path:-logs}" />
    <property name="LOG_USER_NAME" value="${log.user_name:-default}" />

    <!-- Is used to mask the users-input -->
    <conversionRule conversionWord="maskedMsg" converterClass="kundenverwaltung.logger.logback.LogbackMaskingConverter"/>

    <appender name="MASK" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/%d{yyyy-MM-dd}_${LOG_USER_NAME}.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/%d{yyyy-MM-dd}_${LOG_USER_NAME}.log</fileNamePattern>
        </rollingPolicy>

        <prudent>true</prudent>

        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="kundenverwaltung.logger.logback.EncryptionPatternLayout">
                <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{1}:%line - %maskedMsg%n%ex</pattern>
            </layout>
        </encoder>
    </appender>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{1} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="MASK" />
        <appender-ref ref="CONSOLE" />
    </root>
</configuration>