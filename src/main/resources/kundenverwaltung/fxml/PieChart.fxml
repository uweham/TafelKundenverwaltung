<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="kundenverwaltung.controller.PieChartController">
    <children>
        <TextField fx:id="queryField" layoutX="14.0" layoutY="14.0" prefWidth="400.0" promptText="Geben Sie Ihre SQL-Abfrage hier ein..." />
        <Button layoutX="420.0" layoutY="14.0" mnemonicParsing="false" text="Laden" onAction="#loadPieChartData" />
        <PieChart fx:id="pieChart" layoutX="14.0" layoutY="50.0" prefHeight="300.0" prefWidth="400.0" />
    </children>
</AnchorPane>
