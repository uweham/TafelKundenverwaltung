<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="548.0" prefWidth="447.0" xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="kundenverwaltung.controller.PrintConsentForm">
    <children>
        <Pane layoutY="51.0" prefHeight="493.0" prefWidth="447.0" AnchorPane.bottomAnchor="4.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="51.0">
            <children>
                <Label fx:id="labelTemplate" layoutX="14.0" layoutY="4.0" text="Vorlage:"/>
                <ComboBox fx:id="cbVorlage" layoutX="14.0" layoutY="24.0" prefHeight="31.0"
                          prefWidth="418.0"/>
                <RadioButton fx:id="rbAktuellerKunde" layoutX="14.0" layoutY="78.0"
                             mnemonicParsing="false" disable="true"
                             onAction="#checkClientsFromDistributionPoints" text="Aktuellen Kunden">
                    <toggleGroup>
                        <ToggleGroup fx:id="waehleKunde"/>
                    </toggleGroup>
                </RadioButton>
                <RadioButton fx:id="rbAlleKunden" layoutX="14.0" layoutY="99.0"
                             mnemonicParsing="false" onAction="#checkClientsFromDistributionPoints"
                             text="Alle Kunden folgender Verteilstelle" toggleGroup="$waehleKunde"
                             />
                <ComboBox fx:id="cbVerteilstelle" layoutX="14.0" layoutY="147.0" prefHeight="31.0"
                          prefWidth="286.0" />
                <ComboBox fx:id="cbWarentyp" layoutY="140.0" prefHeight="31.0" prefWidth="404.0" visible="false" />
                <ComboBox fx:id="cbSortierReihenfolge" layoutX="274.0" layoutY="201.0" prefHeight="3.0" prefWidth="166.0" visible="false"/>
                <ComboBox fx:id="cbSortierenNach" layoutY="201.0" prefHeight="3.0" prefWidth="253.0" visible="false" />
                <Label fx:id="lbVerteilstelle" layoutX="14.0" layoutY="127.0"
                       text="Verteilstelle:"/>
                <CheckBox fx:id="cbxAutomatischEinstellen" layoutX="318.0" layoutY="143.0"
                          mnemonicParsing="false" prefHeight="34.0" prefWidth="115.0"
                          text="automatisch &#10;einstellen" />
                <CheckBox fx:id="cbxArchivierteKunden" layoutX="11.0" layoutY="206.0"
                          mnemonicParsing="false" text="Auch archivierte Kunden" />
                <CheckBox fx:id="cbxGesperrteKunden" layoutX="11.0" layoutY="230.0"
                          mnemonicParsing="false" prefHeight="17.0" prefWidth="174.0"
                          text="Auch gesperrte Kunden" />
                <CheckBox fx:id="cbxEinstellungenAlsStandard" layoutX="14.0" layoutY="413.0"
                          mnemonicParsing="false" text="Diese Einstellungen als Standard speichern">
                    <font>
                        <Font size="11.0"/>
                    </font>
                </CheckBox>
                <Separator layoutY="391.0" prefWidth="445.0"/>
                <Separator layoutY="187.0" prefHeight="3.0" prefWidth="447.0"/>
                <Button fx:id="buttonRun" layoutX="15.0" layoutY="448.0" mnemonicParsing="false"
                        onAction="#createAllConsentForms" prefHeight="31.0" prefWidth="82.0"
                        text="Ausführen"/>
                <Button fx:id="buttonCancel" layoutX="350.0" layoutY="448.0" mnemonicParsing="false"
                        onAction="#cancelPrintOthers" prefHeight="31.0" prefWidth="82.0"
                        text="Abbrechen"/>
            </children>
        </Pane>
        <Label fx:id="labelHeader" alignment="CENTER" layoutX="100.0" layoutY="44.0"
               prefHeight="51.0" prefWidth="447.0" text="Ausgabe von Benutzerdefinierten Daten"
               textFill="#ee6f00" AnchorPane.bottomAnchor="497.0" AnchorPane.leftAnchor="0.0"
               AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"/>
    </children>
</AnchorPane>
