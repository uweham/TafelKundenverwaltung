<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0" prefWidth="1040.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="kundenverwaltung.controller.server.UserListController">
    <top>
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>
            <children>
                <Label text="Benutzerverwaltung">
                    <font>
                        <Font name="System Bold" size="18" />
                    </font>
                </Label>
                <TextField fx:id="suchTextFeld" promptText="Benutzer nach Name oder UUID suchen..." />
            </children>
        </VBox>
    </top>

    <center>
        <TableView fx:id="benutzerTabelle" onMouseClicked="#handleBenutzerBearbeiten" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="idSpalte" prefWidth="75.0" text="UUID" />
                <TableColumn fx:id="benutzernameSpalte" prefWidth="250.0" text="Benutzer" />
                <TableColumn fx:id="rollenSpalte" prefWidth="400.0" text="Rolle" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <BorderPane.margin>
                <Insets left="15.0" right="15.0" />
            </BorderPane.margin>
        </TableView>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>
            <children>
                <Button fx:id="neuButton" onAction="#handleNeuerBenutzer" text="Neu..." />
                <Button fx:id="bearbeitenButton" onAction="#handleBearbeiten" text="Bearbeiten..." />
                <Button fx:id="loeschenButton" onAction="#handleBenutzerLoeschen" text="Löschen" />
                <HBox HBox.hgrow="ALWAYS" />
                <Button fx:id="schliessenButton" onAction="#handleSchliessen" text="Schließen" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
