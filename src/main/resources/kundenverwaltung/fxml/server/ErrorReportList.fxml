<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0" prefWidth="1040.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="kundenverwaltung.controller.server.ErrorReportListController">

    <top>
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>
            <children>
                <Label text="Fehlerberichte">
                    <font>
                        <Font name="System Bold" size="18" />
                    </font>
                </Label>
                <TextField fx:id="searchTextField" promptText="Fehlerbericht nach Titel oder UUID suchen..." />
            </children>
        </VBox>
    </top>

    <center>
        <TableView fx:id="errorReportTable" onMouseClicked="#handleErrorEdit" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="uuidColumn" prefWidth="67.0" text="UUID" />
                <TableColumn fx:id="titleColumn" prefWidth="229.0" text="Titel" />
                <TableColumn fx:id="descriptionColumn" prefWidth="354.0" text="Beschreibung" />
                <TableColumn fx:id="usernameColumn" prefWidth="161.0" text="Mitarbeiter" />
                <TableColumn fx:id="statusColumn" prefWidth="83.0" text="Status" />
                <TableColumn fx:id="createdAtColumn" prefWidth="120.0" text="Zugestellt am" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <BorderPane.margin>
                <Insets left="15.0" right="15.0" />
            </BorderPane.margin>
        </TableView>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>
            <children>
                <Button fx:id="editButton" onAction="#handleEdit" text="Bearbeiten..." />
                <Button fx:id="deleteButton" onAction="#handleDeleteError" text="Löschen" />
                <HBox HBox.hgrow="ALWAYS" />
                <Button fx:id="closeButton" onAction="#handleClose" text="Schließen" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
